---
import BaseLayout from "./BaseLayout.astro";
import "../styles/blogpost.css";
const { frontmatter } = Astro.props;
const slug = Astro.url.pathname.replace(/\/$/, "").split("/").pop();
---

<BaseLayout pageTitle={frontmatter.title} pageLang={frontmatter.lang} prose={true}>
    <nav class="crumb" aria-label="Breadcrumb" slot="before-title" lang="en">
        <a href="/">~</a> / <a href="/blog">blog</a> / <span>{slug}</span>
    </nav>
    <div class="post_header">
        <div class="post_meta" lang="en">
            <time datetime={String(frontmatter.pubDate).slice(0, 10)} class="post_date">
                {String(frontmatter.pubDate).slice(0, 10)}
            </time>
            <span class="sep">·</span>
            <span lang={frontmatter.lang} class="post_author">{frontmatter.author}</span>
            <span class="sep">·</span>
            <span class="tag">{frontmatter.lang}</span>
        </div>
        <p lang={frontmatter.lang} class="post_description"><em>{frontmatter.description}</em></p>
    </div>
    <article class="prose">
        <slot />
    </article>
    <div class="endmark" lang="en" aria-hidden="true">— ✦ —</div>
</BaseLayout>
