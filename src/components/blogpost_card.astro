---
import "../styles/blogpage.css"
const { blogTitle, blogDescription, blogDate, blogUrl, blogLang } = Astro.props;
---

<li class="post-row">
    <span class="post-row-meta">
        <time datetime={String(blogDate).slice(0, 10)}>{String(blogDate).slice(0, 10)}</time>
        <span class="tag">{blogLang}</span>
    </span>
    <a href={blogUrl} class="post-row-title" lang={blogLang}>{blogTitle}</a>
    <p class="post-row-desc" lang={blogLang}>{blogDescription}</p>
</li>
